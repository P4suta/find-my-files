* text=auto

*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
justfile text eol=lf

# Generated from xtask publish::FIRST_PARTY_PES and read verbatim by the
# verify-signatures composite action + pinned by an xtask drift test: keep it LF
# so the working tree matches the committed bytes on every platform.
.github/actions/verify-signatures/first-party-pes.txt text eol=lf

*.cs     text eol=crlf
*.xaml   text eol=crlf
*.ps1    text eol=crlf
*.sln    text eol=crlf
*.csproj text eol=crlf
*.manifest text eol=crlf

*.png binary
*.ico binary
*.bin binary
*.fmfidx binary

# The golden corpus is byte-exact by definition (ADR-0018): the Rust/C# pin
# tests compare file bytes verbatim, so EOL conversion must never touch it.
# Without this, a checkout smudges the JSON goldens to CRLF and the pins
# break (the .bin files only survived via the binary heuristic above).
contract/golden/** -text
