# All build output (ADR-0021): the cargo target dirs (build/engine, build/xtask),
# the C# bin output (build/app), the publish bundle (build/dist), release packages
# (build/package), release SBOMs (build/sbom) and the staged docs site (build/site,
# build/docs-book) — one tree, one ignore line.
build/

# C# intermediate output stays in-tree: relocating obj needs a
# Directory.Build.props, which CLAUDE.md forbids (ADR-0021).
app/**/obj/

# IDE / editor state
.vs/
*.user

# Test + coverage artifacts produced outside build/
screenshots/
test-results.json
**/*.cobertura.xml

# Engine runtime artifacts
*.fmfidx
engine/crates/fmf-core/testdata/large/

# Local-only tool overrides
mise.local.toml
.mise.local.toml

# npm deps pulled into the tree by the actionlint action (CI hygiene job);
# never committed, but keep an accidental local `act`/action run out of git.
node_modules/

# Claude Code local working dir (scheduled task locks, etc.)
.claude/

# Internal working notes — never publish
CLAUDE.md

# Untracked screenshot scratch
.tmp-shots/
