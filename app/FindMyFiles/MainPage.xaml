<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FindMyFiles.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:FindMyFiles.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svc="using:FindMyFiles.Services"
    xmlns:views="using:FindMyFiles.Views"
    xmlns:vm="using:FindMyFiles.ViewModels"
    mc:Ignorable="d">

    <!--  AllowDrop: a dropped folder injects a path: filter, a dropped file searches its name (drop-in only; rows are not drag-out sources).  -->
    <Grid
        AllowDrop="True"
        DragOver="Page_DragOver"
        Drop="Page_Drop">

        <!--  Empty(空クエリ): 検索行を領域いっぱい(*)にして検索バーを縦中央に、結果行は畳む
              (Raycast/Spotlight の初期画面)。Results(クエリ有): 検索行は Auto(上固定)・結果行(*)。
              状態(件数/エンジン等)と診断は常設をやめ設定(歯車)に集約した。  -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SearchStates">
                <VisualState x:Name="EmptyState">
                    <VisualState.Setters>
                        <!--  検索バーを縦中央へ: SearchRow を * に、結果行は畳む。行高は VisualState で
                              明示制御(Visibility=Collapsed だと Auto 行が復帰時に再計算されない罠を回避)。  -->
                        <Setter Target="SearchRow.Height" Value="*" />
                        <Setter Target="ResultsRow.Height" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="ResultsState" />
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <!--  通知バナー(Auto・常時表示)。EmptyState で潰れる ResultsRow から
                  独立させ、起動直後(空クエリ)でも警告が見えるようにする。  -->
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="SearchRow" Height="Auto" />
            <!--  結果(*)は検索バー直下から画面下端まで使う(フッター撤去済み・衝突相手なし)。  -->
            <RowDefinition x:Name="ResultsRow" Height="*" />
            <!--  診断パネル。既定は畳む(0)・開くと最下部に出る。  -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  通知バナー(Row 0)。検索バーと横位置(MaxWidth/Margin)を揃える。
              専用行なので結果リストとは重ならず、EmptyState でも表示される。  -->
        <ItemsControl
            Grid.Row="0"
            MaxWidth="860"
            Margin="24,16,24,0"
            AutomationProperties.AutomationId="NotifyBar"
            ItemsSource="{x:Bind ViewModel.Notifications.Items}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:AppNotification">
                    <InfoBar
                        Title="{x:Bind Message}"
                        Margin="0,0,0,4"
                        Closed="Notification_Closed"
                        IsOpen="True"
                        Message="{x:Bind Detail}"
                        Severity="{x:Bind conv:UiConverters.ToInfoSeverity(Severity)}">
                        <InfoBar.ActionButton>
                            <Button
                                Click="{x:Bind Invoke}"
                                Content="{x:Bind ActionLabel}"
                                Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(ActionLabel)}" />
                        </InfoBar.ActionButton>
                    </InfoBar>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  検索バー(Row 0)。Empty では行が * で縦中央、Results では Auto で上。
              位置変化は RepositionThemeTransition で滑らかに。  -->
        <Grid
            Grid.Row="1"
            MaxWidth="860"
            Margin="24,16,24,0"
            VerticalAlignment="Center"
            ColumnSpacing="8"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">
            <Grid.Transitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </Grid.Transitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--  Search box: a plain TextBox on purpose (AutoSuggestBox's accept semantics fight live filtering — docs/ARCHITECTURE.md).  -->
            <TextBox
                x:Name="SearchBox"
                x:Uid="SearchBox"
                Grid.Column="0"
                AutomationProperties.AutomationId="SearchBox"
                KeyDown="SearchBox_KeyDown"
                Style="{StaticResource LauncherSearchBoxStyle}"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <!--  フォーカス時の青い2pxアクセント下線を消す(Google 風に常時1pxの丸枠だけ)。
                      TextBox テンプレートが Focused 状態でこの2リソースを使うので、この TextBox
                      スコープだけで上書き(他の TextBox には波及させない)。  -->
                <TextBox.Resources>
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
                    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="ControlStrokeColorDefaultBrush" />
                </TextBox.Resources>
            </TextBox>
            <!--  検索バーをすっきり保つため、絞り込み・隠しファイル・並べ替え・状態表示・診断は
                  すべて設定ボタン1つに集約(常設フッターは廃止)。  -->
            <Button
                x:Name="OptionsButton"
                Grid.Column="1"
                Width="56"
                Height="56"
                Padding="0"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="OptionsButton"
                CornerRadius="28">
                <FontIcon FontSize="16" Glyph="&#xE713;" />
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <ToggleMenuFlyoutItem
                            x:Uid="OptFocused"
                            AutomationProperties.AutomationId="OptFocused"
                            IsChecked="{x:Bind ViewModel.FocusedSearch, Mode=TwoWay}" />
                        <ToggleMenuFlyoutItem
                            x:Uid="OptSystem"
                            AutomationProperties.AutomationId="OptSystem"
                            IsChecked="{x:Bind ViewModel.IncludeHiddenSystem, Mode=TwoWay}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutSubItem x:Uid="SortHeaderItem">
                            <RadioMenuFlyoutItem
                                x:Uid="SortName"
                                AutomationProperties.AutomationId="SortName"
                                Click="HeaderName_Click"
                                GroupName="SortOrder"
                                IsChecked="True" />
                            <RadioMenuFlyoutItem
                                x:Uid="SortSize"
                                AutomationProperties.AutomationId="SortSize"
                                Click="HeaderSize_Click"
                                GroupName="SortOrder" />
                            <RadioMenuFlyoutItem
                                x:Uid="SortDate"
                                AutomationProperties.AutomationId="SortDate"
                                Click="HeaderDate_Click"
                                GroupName="SortOrder" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <!--  状態(旧フッター)はサブ項目に押し込み、オプションと同列にしない(情報なので無効表示)。  -->
                        <MenuFlyoutSubItem x:Uid="StatusMenuItem" AutomationProperties.AutomationId="StatusMenu">
                            <MenuFlyoutItem
                                AutomationProperties.AutomationId="StatusState"
                                IsEnabled="False"
                                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                            <MenuFlyoutItem
                                AutomationProperties.AutomationId="StatusCount"
                                IsEnabled="False"
                                Text="{x:Bind ViewModel.Results.CountText, Mode=OneWay}"
                                Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(ViewModel.Results.CountText), Mode=OneWay}" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Uid="LangMenu" AutomationProperties.AutomationId="LangMenu">
                            <RadioMenuFlyoutItem
                                x:Name="LangAuto"
                                x:Uid="LangSystem"
                                AutomationProperties.AutomationId="LangSystem"
                                Click="Language_Click"
                                GroupName="UiLanguage"
                                Tag="auto" />
                            <RadioMenuFlyoutItem
                                x:Name="LangJa"
                                AutomationProperties.AutomationId="LangJa"
                                Click="Language_Click"
                                GroupName="UiLanguage"
                                Tag="ja"
                                Text="日本語" />
                            <RadioMenuFlyoutItem
                                x:Name="LangEn"
                                AutomationProperties.AutomationId="LangEn"
                                Click="Language_Click"
                                GroupName="UiLanguage"
                                Tag="en"
                                Text="English" />
                            <RadioMenuFlyoutItem
                                x:Name="LangZh"
                                AutomationProperties.AutomationId="LangZh"
                                Click="Language_Click"
                                GroupName="UiLanguage"
                                Tag="zh-Hans"
                                Text="简体中文" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem
                            x:Uid="DiagToggle"
                            AutomationProperties.AutomationId="DiagToggle"
                            Click="PerfPanel_MenuClick" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            x:Uid="ServiceManageMenu"
                            AutomationProperties.AutomationId="ServiceManageMenu"
                            Click="ServiceManager_MenuClick" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!--  結果(Row 1・*)。MaxWidth で中央寄せ。下マージンは画面下端の余白(フッター撤去済み)。  -->
        <Grid
            x:Name="ResultsArea"
            Grid.Row="2"
            MaxWidth="860"
            Margin="24,12,24,16"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">

            <!--  Results. ItemsPanel stays ItemsStackPanel (CLAUDE.md UI固定則).
                  ItemsSource is bound OneTime by design: the VirtualResultList
                  instance lives as long as the page; new results arrive via a
                  seeded Reset, never by swapping the ItemsSource (ADR-0015).  -->
            <!--  結果は * 行いっぱいに表示(ウィンドウ全体を使い、スクロールバーもフル丈)。
                  仮想化は ItemsStackPanel＋IItemsRangeInfo が担う(行の高さ制約は不要)。
                  フッターは別の Auto 行(Row 3)にあるので構造上この ListView と重なり得ない。  -->
            <ListView
                x:Name="ResultsList"
                AutomationProperties.AutomationId="ResultsList"
                DoubleTapped="ResultsList_DoubleTapped"
                ItemsSource="{x:Bind ViewModel.Results.ResultsSource}"
                KeyDown="ResultsList_KeyDown"
                SelectionMode="Extended"
                ShowsScrollingPlaceholders="True">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                        <Setter Property="MinHeight" Value="52" />
                        <Setter Property="Padding" Value="12,6,12,6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ResultRow">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="22"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="{x:Bind Glyph, Mode=OneWay}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource ResultNameTextStyle}" Text="{x:Bind Name, Mode=OneWay}" />
                                <TextBlock
                                    x:Phase="1"
                                    Style="{StaticResource ResultPathTextStyle}"
                                    Text="{x:Bind ParentPath, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                MinWidth="96"
                                VerticalAlignment="Center">
                                <TextBlock
                                    x:Phase="2"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource ResultMetaTextStyle}"
                                    Text="{x:Bind SizeText, Mode=OneWay}" />
                                <TextBlock
                                    x:Phase="2"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource ResultMetaTextStyle}"
                                    Text="{x:Bind DateText, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            x:Uid="MnuOpen"
                            AutomationProperties.AutomationId="MnuOpen"
                            Click="MenuOpen_Click" />
                        <MenuFlyoutItem
                            x:Uid="MnuOpenPath"
                            AutomationProperties.AutomationId="MnuOpenPath"
                            Click="MenuOpenPath_Click" />
                        <MenuFlyoutItem
                            x:Uid="MnuCopyPath"
                            AutomationProperties.AutomationId="MnuCopyPath"
                            Click="MenuCopyPath_Click" />
                    </MenuFlyout>
                </ListView.ContextFlyout>
            </ListView>
        </Grid>

        <!--  Performance panel(設定→診断 で開閉)。最下部(Row 3)に出る。  -->
        <views:PerfPanel
            Grid.Row="3"
            ViewModel="{x:Bind ViewModel.Perf}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.Perf.IsOpen), Mode=OneWay}" />

        <!--  未接続(空エンジン)時のセットアップ画面。検索バー等は IsReady で畳まれ、
              これが画面中央に出る。主ボタンはワンクリックで登録→自動再起動。
              IsDisconnected は起動時固定なので OneTime。  -->
        <StackPanel
            Grid.Row="0"
            Grid.RowSpan="4"
            MaxWidth="420"
            Padding="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsDisconnected)}">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="44"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE721;" />
            <TextBlock
                x:Uid="SetupTitle"
                HorizontalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                TextAlignment="Center" />
            <TextBlock
                x:Uid="SetupBody"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Button
                x:Name="EnableSearchButton"
                x:Uid="EnableSearch"
                HorizontalAlignment="Center"
                AutomationProperties.AutomationId="EnableSearch"
                Click="EnableSearch_Click"
                IsEnabled="{x:Bind ViewModel.SetupNotBusy, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(ViewModel.SetupStatus), Mode=OneWay}">
                <ProgressRing
                    Width="16"
                    Height="16"
                    IsActive="{x:Bind ViewModel.SetupBusy, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.SetupStatus, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
