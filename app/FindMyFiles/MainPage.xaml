<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FindMyFiles.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:FindMyFiles.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hl="using:FindMyFiles.Highlighting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svc="using:FindMyFiles.Services"
    xmlns:vm="using:FindMyFiles.ViewModels"
    mc:Ignorable="d">

    <!--  AllowDrop: a dropped folder injects a path: filter, a dropped file searches its name (drop-in only; rows are not drag-out sources).  -->
    <Grid
        AllowDrop="True"
        DragOver="Page_DragOver"
        Drop="Page_Drop">

        <!--  Empty(空クエリ): 検索行を領域いっぱい(*)にして検索バーを縦中央に、結果行は畳む
              (Raycast/Spotlight の初期画面)。Results(クエリ有): 検索行は Auto(上固定)・結果行(*)。
              状態(件数/エンジン等)と診断は常設をやめ設定(歯車)に集約した。  -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SearchStates">
                <VisualState x:Name="EmptyState">
                    <VisualState.Setters>
                        <!--  検索バーを縦中央へ: SearchRow を * に、結果行は畳む。行高は VisualState で
                              明示制御(Visibility=Collapsed だと Auto 行が復帰時に再計算されない罠を回避)。  -->
                        <Setter Target="SearchRow.Height" Value="*" />
                        <Setter Target="ResultsRow.Height" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="ResultsState" />
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <!--  通知バナー(Auto・常時表示)。EmptyState で潰れる ResultsRow から
                  独立させ、起動直後(空クエリ)でも警告が見えるようにする。  -->
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="SearchRow" Height="Auto" />
            <!--  結果(*)は検索バー直下から画面下端まで使う(フッター撤去済み・衝突相手なし)。  -->
            <RowDefinition x:Name="ResultsRow" Height="*" />
        </Grid.RowDefinitions>

        <!--  通知バナー(Row 0)。検索バーと横位置(MaxWidth/Margin)を揃える。
              専用行なので結果リストとは重ならず、EmptyState でも表示される。  -->
        <ItemsControl
            Grid.Row="0"
            MaxWidth="{StaticResource ContentMaxWidth}"
            Margin="{StaticResource ContentGutterMargin}"
            AutomationProperties.AutomationId="NotifyBar"
            ItemsSource="{x:Bind ViewModel.Notifications.Items}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:AppNotification">
                    <InfoBar
                        Title="{x:Bind Message}"
                        Margin="{StaticResource NotificationItemMargin}"
                        Closed="Notification_Closed"
                        IsOpen="True"
                        Message="{x:Bind Detail}"
                        Severity="{x:Bind conv:UiConverters.ToInfoSeverity(Severity)}">
                        <InfoBar.ActionButton>
                            <Button
                                Click="{x:Bind Invoke}"
                                Content="{x:Bind ActionLabel}"
                                Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(ActionLabel)}" />
                        </InfoBar.ActionButton>
                    </InfoBar>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  検索バー(Row 0)。Empty では行が * で縦中央、Results では Auto で上。
              位置変化は RepositionThemeTransition で滑らかに。  -->
        <Grid
            Grid.Row="1"
            MaxWidth="{StaticResource ContentMaxWidth}"
            Margin="{StaticResource ContentGutterMargin}"
            VerticalAlignment="Center"
            ColumnSpacing="{StaticResource SpacingSmall}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">
            <Grid.Transitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </Grid.Transitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--  Search box: a plain TextBox on purpose (AutoSuggestBox's accept semantics fight live filtering — docs/ARCHITECTURE.md).  -->
            <TextBox
                x:Name="SearchBox"
                Grid.Column="0"
                AutomationProperties.AutomationId="SearchBox"
                KeyDown="SearchBox_KeyDown"
                PlaceholderText="{x:Bind ViewModel.SearchPlaceholder, Mode=OneWay}"
                Style="{StaticResource LauncherSearchBoxStyle}"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <!--  Google 風に常時1pxの丸枠だけにする。TextBox 既定は (1) Focused で青い2px
                      アクセント下線、(2) 通常/ホバー時に ControlElevationBorderBrush(下辺が濃い
                      立体感グラデ)を使う。後者がフォーカスを外したとき「下線/車道」のように見える
                      ので、Focused とあわせて通常・ホバーの枠ブラシも平坦な ControlStrokeColorDefaultBrush
                      に上書きする(この TextBox スコープだけ・他へは波及させない)。  -->
                <TextBox.Resources>
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
                    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="ControlStrokeColorDefaultBrush" />
                    <StaticResource x:Key="TextControlBorderBrush" ResourceKey="ControlStrokeColorDefaultBrush" />
                    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="ControlStrokeColorDefaultBrush" />
                </TextBox.Resources>
            </TextBox>
            <!--  検索バーをすっきり保つため、絞り込み・隠しファイル・並べ替え・状態表示・診断は
                  すべて設定ボタン1つに集約(常設フッターは廃止)。  -->
            <Button
                x:Name="OptionsButton"
                Grid.Column="1"
                Width="{StaticResource SearchControlSize}"
                Height="{StaticResource SearchControlSize}"
                Padding="0"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="OptionsButton"
                Click="OptionsButton_Click"
                CornerRadius="{StaticResource SearchPillCornerRadius}">
                <FontIcon FontSize="{StaticResource IconSizeSmall}" Glyph="&#xE713;" />
            </Button>
        </Grid>

        <!--  結果(Row 1・*)。MaxWidth で中央寄せ。下マージンは画面下端の余白(フッター撤去済み)。  -->
        <Grid
            x:Name="ResultsArea"
            Grid.Row="2"
            MaxWidth="{StaticResource ContentMaxWidth}"
            Margin="{StaticResource ResultsAreaMargin}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsReady)}">

            <!--  Results. ItemsPanel stays ItemsStackPanel (CLAUDE.md UI固定則).
                  ItemsSource is bound OneTime by design: the VirtualResultList
                  instance lives as long as the page; new results arrive via a
                  seeded Reset, never by swapping the ItemsSource (ADR-0015).  -->
            <!--  結果は * 行いっぱいに表示(ウィンドウ全体を使い、スクロールバーもフル丈)。
                  仮想化は ItemsStackPanel＋IItemsRangeInfo が担う(行の高さ制約は不要)。
                  最下行(*)なので下に重なる要素は無い(診断は別ウィンドウへ分離済み)。  -->
            <ListView
                x:Name="ResultsList"
                AutomationProperties.AutomationId="ResultsList"
                DoubleTapped="ResultsList_DoubleTapped"
                ItemsSource="{x:Bind ViewModel.Results.ResultsSource}"
                KeyDown="ResultsList_KeyDown"
                SelectionMode="Extended"
                ShowsScrollingPlaceholders="True">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                        <Setter Property="MinHeight" Value="{StaticResource ListItemMinHeight}" />
                        <Setter Property="Padding" Value="{StaticResource ListItemPadding}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ResultRow">
                        <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource IconSizeLarge}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="{x:Bind Glyph, Mode=OneWay}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock
                                    Style="{StaticResource ResultNameTextStyle}"
                                    hl:HighlightText.Source="{x:Bind Name, Mode=OneWay}"
                                    hl:HighlightText.Ranges="{x:Bind NameRanges, Mode=OneWay}" />
                                <TextBlock
                                    x:Phase="1"
                                    Style="{StaticResource ResultPathTextStyle}"
                                    hl:HighlightText.Source="{x:Bind ParentPath, Mode=OneWay}"
                                    hl:HighlightText.Ranges="{x:Bind PathRanges, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                MinWidth="{StaticResource MetaColumnMinWidth}"
                                VerticalAlignment="Center">
                                <TextBlock
                                    x:Phase="2"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource ResultMetaTextStyle}"
                                    Text="{x:Bind SizeText, Mode=OneWay}" />
                                <TextBlock
                                    x:Phase="2"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource ResultMetaTextStyle}"
                                    Text="{x:Bind DateText, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            x:Uid="MnuOpen"
                            AutomationProperties.AutomationId="MnuOpen"
                            Click="MenuOpen_Click" />
                        <MenuFlyoutItem
                            x:Uid="MnuOpenPath"
                            AutomationProperties.AutomationId="MnuOpenPath"
                            Click="MenuOpenPath_Click" />
                        <MenuFlyoutItem
                            x:Uid="MnuCopyPath"
                            AutomationProperties.AutomationId="MnuCopyPath"
                            Click="MenuCopyPath_Click" />
                    </MenuFlyout>
                </ListView.ContextFlyout>
            </ListView>

            <!--  検索したが0件のとき、空白の代わりに Fluent 空状態を出す(クエリ有り・結果着地後のみ)。
                  ListView の兄弟オーバーレイで、ItemsSource は一切触らない(ADR-0015)。  -->
            <StackPanel
                MaxWidth="{StaticResource SetupMaxWidth}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="{StaticResource SpacingSmall}"
                Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.HasNoResults), Mode=OneWay}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource IconSizeXLarge}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE721;" />
                <TextBlock
                    x:Uid="NoResultsTitle"
                    AutomationProperties.AutomationId="NoResultsTitle"
                    HorizontalAlignment="Center"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    TextAlignment="Center" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="{x:Bind ViewModel.NoResultsText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <!--  未接続(空エンジン)時のセットアップ画面。検索バー等は IsReady で畳まれ、
              これが画面中央に出る。主ボタンはワンクリックで登録→自動再起動。
              IsDisconnected は起動時固定なので OneTime。  -->
        <StackPanel
            Grid.Row="0"
            Grid.RowSpan="3"
            MaxWidth="{StaticResource SetupMaxWidth}"
            Padding="{StaticResource PageContentPadding}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="{StaticResource SpacingLarge}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(ViewModel.IsDisconnected)}">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="{StaticResource IconSizeXLarge}"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE721;" />
            <TextBlock
                x:Uid="SetupTitle"
                HorizontalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                TextAlignment="Center" />
            <TextBlock
                x:Uid="SetupBody"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Button
                x:Name="EnableSearchButton"
                x:Uid="EnableSearch"
                HorizontalAlignment="Center"
                AutomationProperties.AutomationId="EnableSearch"
                Click="EnableSearch_Click"
                IsEnabled="{x:Bind ViewModel.SetupNotBusy, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
            <!--  非昇格スコープ経路(ADR-0024): 管理者CTAを主役に保ち、その下に
                  控えめなリンク1つだけ。実体(フォルダ選択)は別画面=
                  ScopeManagerDialog に逃がし、setup画面のごちゃつきを避ける。  -->
            <TextBlock
                x:Uid="SetupOrDivider"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}" />
            <HyperlinkButton
                x:Uid="ScopeSetupLink"
                HorizontalAlignment="Center"
                AutomationProperties.AutomationId="ScopeSetupLink"
                Click="ScopeSetup_Click" />
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="{StaticResource SpacingSmall}"
                Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(ViewModel.SetupStatus), Mode=OneWay}">
                <ProgressRing
                    Width="{StaticResource ProgressRingSizeSmall}"
                    Height="{StaticResource ProgressRingSizeSmall}"
                    IsActive="{x:Bind ViewModel.SetupBusy, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.SetupStatus, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
