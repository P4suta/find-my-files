<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FindMyFiles.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:FindMyFiles"
    xmlns:svc="using:FindMyFiles.Services"
    xmlns:vm="using:FindMyFiles.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F12" Invoked="PerfPanel_Toggle" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- Search box: a plain TextBox on purpose (AutoSuggestBox's accept
             semantics fight live filtering — docs/ARCHITECTURE.md). -->
        <Grid Grid.Row="0" Margin="12,8,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="SearchBox"
                Grid.Column="0"
                AutomationProperties.AutomationId="SearchBox"
                KeyDown="SearchBox_KeyDown"
                PlaceholderText="検索  (ext:  path:  size:  dm:  regex:  |  !  &quot;&quot;)"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ToggleButton
                Grid.Column="1"
                VerticalAlignment="Stretch"
                AutomationProperties.AutomationId="ToggleSystem"
                AutomationProperties.Name="システム・隠しファイルを含める"
                IsChecked="{x:Bind ViewModel.IncludeHiddenSystem, Mode=TwoWay}"
                ToolTipService.ToolTip="システム・隠しファイルを含める">
                <FontIcon FontSize="14" Glyph="&#xED25;" />
            </ToggleButton>
        </Grid>

        <!-- Notification stack: the visible end of every error path. -->
        <ItemsControl
            Grid.Row="1"
            Margin="12,0,12,4"
            AutomationProperties.AutomationId="NotifyBar"
            ItemsSource="{x:Bind ViewModel.Notifications}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:AppNotification">
                    <InfoBar
                        Title="{x:Bind Message}"
                        Margin="0,0,0,4"
                        Closed="Notification_Closed"
                        IsOpen="True"
                        Message="{x:Bind Detail}"
                        Severity="{x:Bind local:MainPage.ToInfoSeverity(Severity)}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Column headers -->
        <Grid Grid.Row="2" Margin="16,0,28,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                AutomationProperties.AutomationId="HeaderName"
                Background="Transparent"
                BorderThickness="0"
                Click="HeaderName_Click"
                Content="名前"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left" />
            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="パス" />
            <Button
                Grid.Column="2"
                AutomationProperties.AutomationId="HeaderSize"
                Background="Transparent"
                BorderThickness="0"
                Click="HeaderSize_Click"
                Content="サイズ"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right" />
            <Button
                Grid.Column="3"
                AutomationProperties.AutomationId="HeaderDate"
                Background="Transparent"
                BorderThickness="0"
                Click="HeaderDate_Click"
                Content="更新日時"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left" />
        </Grid>

        <!-- Results. ItemsPanel stays ItemsStackPanel (CLAUDE.md UI固定則). -->
        <ListView
            x:Name="ResultsList"
            Grid.Row="3"
            AutomationProperties.AutomationId="ResultsList"
            DoubleTapped="ResultsList_DoubleTapped"
            ItemsSource="{x:Bind ViewModel.ResultsSource, Mode=OneWay}"
            KeyDown="ResultsList_KeyDown"
            SelectionMode="Extended"
            ShowsScrollingPlaceholders="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="MinHeight" Value="30" />
                    <Setter Property="Padding" Value="16,2,12,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ResultRow">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontSize="14"
                                Glyph="{x:Bind Glyph, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="1"
                            x:Phase="1"
                            Margin="8,0,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ParentPath, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="2"
                            x:Phase="2"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind SizeText, Mode=OneWay}" />
                        <TextBlock
                            Grid.Column="3"
                            x:Phase="2"
                            Margin="8,0,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind DateText, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        AutomationProperties.AutomationId="MnuOpen"
                        Click="MenuOpen_Click"
                        Text="開く" />
                    <MenuFlyoutItem
                        AutomationProperties.AutomationId="MnuOpenPath"
                        Click="MenuOpenPath_Click"
                        Text="フォルダーを開いてファイルを選択" />
                    <MenuFlyoutItem
                        AutomationProperties.AutomationId="MnuCopyPath"
                        Click="MenuCopyPath_Click"
                        Text="パスをコピー" />
                </MenuFlyout>
            </ListView.ContextFlyout>
        </ListView>

        <!-- Performance panel (F12). Rendering of the stage bar / sparkline
             happens in code-behind — it is diagnostic chrome, not app data. -->
        <Border
            Grid.Row="4"
            Padding="16,8"
            AutomationProperties.AutomationId="PerfPanel"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind BoolToVis(ViewModel.IsPerfPanelOpen), Mode=OneWay}">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock
                        x:Name="PerfHeadline"
                        FontFamily="Consolas"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <Grid x:Name="StageBar" Height="14" />
                    <TextBlock
                        x:Name="StageLegend"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid Height="44" Margin="0,4,0,0">
                        <Polyline
                            x:Name="Spark"
                            Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                            StrokeThickness="1.5" />
                    </Grid>
                    <TextBlock
                        x:Name="HistText"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Name="ErrorsText"
                        AutomationProperties.AutomationId="PerfErrors"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" MinWidth="280" Spacing="4">
                    <TextBlock
                        x:Name="VolumesText"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        x:Name="UsnFeed"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Name="CountersText"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                    <Button
                        AutomationProperties.AutomationId="CopyDiag"
                        Click="CopyDiag_Click"
                        Content="診断情報をコピー"
                        FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="5" Padding="16,4" BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <TextBlock
                HorizontalAlignment="Left"
                AutomationProperties.AutomationId="StatusCount"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.CountText, Mode=OneWay}" />
            <TextBlock
                HorizontalAlignment="Right"
                AutomationProperties.AutomationId="StatusState"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
