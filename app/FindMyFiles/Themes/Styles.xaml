<?xml version="1.0" encoding="utf-8" ?>
<!--
    Control styles, factored out of App.xaml and driven by the design tokens.
    Colours stay on Fluent {ThemeResource} brushes (no hardcoded colour);
    dimensions reference {StaticResource} tokens. Merged after the token
    dictionaries AND after XamlControlsResources (whose DefaultTextBoxStyle and
    type-ramp styles these derive from) so every StaticResource resolves.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Raycast/Spotlight 風の大きな中央検索ボックス。色は全て Fluent ThemeResource。  -->
    <Style
        x:Key="LauncherSearchBoxStyle"
        BasedOn="{StaticResource DefaultTextBoxStyle}"
        TargetType="TextBox">
        <Setter Property="FontSize" Value="{StaticResource SearchBoxFontSize}" />
        <Setter Property="MinHeight" Value="{StaticResource SearchControlSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <!--  WinUI の単一行 TextBox は VerticalContentAlignment では縦中央にならず、
              実質 Padding の上値でテキスト位置が決まる。高さ56・FontSize20 で中央に
              来るよう上下14(SearchBoxPadding)。左右は角丸に合わせ広め。  -->
        <Setter Property="Padding" Value="{StaticResource SearchBoxPadding}" />
        <!--  高さ56の半分=28(SearchPillCornerRadius)で左右が完全な半円(ピル)に。  -->
        <Setter Property="CornerRadius" Value="{StaticResource SearchPillCornerRadius}" />
    </Style>

    <!--  結果行: ファイル名(上段)  -->
    <Style
        x:Key="ResultNameTextStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!--  結果行: パス(下段・控えめ)  -->
    <Style
        x:Key="ResultPathTextStyle"
        BasedOn="{StaticResource CaptionTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!--  結果行: サイズ/日時(右端・最も控えめ)  -->
    <Style
        x:Key="ResultMetaTextStyle"
        BasedOn="{StaticResource CaptionTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
    </Style>
</ResourceDictionary>
