<?xml version="1.0" encoding="utf-8" ?>
<!--
    Design-token primitives — the raw, reusable scales. Single source of truth
    for spacing and icon sizing; call sites reference these by name so no
    spacing/size literal is ever written inline (CLAUDE.md: 仕組みから統一).

    Layering:  Primitives (this file, raw scale)
            →  Tokens.Semantic.xaml (purpose-named dimensions + Thickness shapes)
            →  Styles.xaml (control styles).
    Merged in that order from App.xaml so every StaticResource lookup resolves.

    Type rules — WinUI assigns the resolved resource object directly; there is
    NO double→Thickness coercion, so the property type decides the token type:
      • x:Double  → Spacing / ColumnSpacing / RowSpacing / Width / Height /
                    FontSize / Min*/Max* / StrokeThickness   (double-typed)
      • Thickness → Margin / Padding / BorderThickness        (see Semantic)
    Tokens are theme-invariant → referenced via {StaticResource}, never
    {ThemeResource} (colours stay {ThemeResource}). Base grid = 4px.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Spacing scale (4px grid). For Spacing / ColumnSpacing / RowSpacing.  -->
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">12</x:Double>
    <x:Double x:Key="SpacingLarge">16</x:Double>
    <x:Double x:Key="SpacingXLarge">24</x:Double>
    <x:Double x:Key="SpacingXXLarge">32</x:Double>

    <!--  Icon glyph sizes (FontIcon.FontSize). A distinct axis from the Fluent
          type ramp, which still governs all text.  -->
    <x:Double x:Key="IconSizeXSmall">12</x:Double>
    <x:Double x:Key="IconSizeSmall">16</x:Double>
    <x:Double x:Key="IconSizeMedium">20</x:Double>
    <x:Double x:Key="IconSizeLarge">22</x:Double>
    <x:Double x:Key="IconSizeXLarge">44</x:Double>
</ResourceDictionary>
