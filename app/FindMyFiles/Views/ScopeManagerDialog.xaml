<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="FindMyFiles.Views.ScopeManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:FindMyFiles.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="ScopeDialog"
    AutomationProperties.AutomationId="ScopeManagerDialog"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind VM.CanStartScope, Mode=OneWay}"
    PrimaryButtonClick="Apply_Click"
    mc:Ignorable="d">

    <!--  非昇格スコープモード(ADR-0024)の索引対象フォルダーを索引中に選び直す。
          「変更して再起動」はエンジンに稼働中のroot差し替えAPIが無いため
          (index_start_scope は既存scopeスロットで no-op)、保存+再起動で再walkする。  -->
    <StackPanel MinWidth="380" Spacing="12">
        <TextBlock
            x:Uid="ScopeDialogBody"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            TextWrapping="Wrap" />

        <!--  選択済みフォルダー一覧(各行に削除ボタン)。setup画面と同じ
              ObservableCollection を共有(索引中は setup画面が畳まれているので競合なし)。  -->
        <ItemsControl AutomationProperties.AutomationId="ScopeDialogFolders" ItemsSource="{x:Bind VM.ScopeFolders, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid Margin="0,2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind}" />
                        <Button
                            Grid.Column="1"
                            Padding="8,4"
                            Click="RemoveFolder_Click"
                            Content="&#xE711;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="12"
                            Tag="{x:Bind}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button
            x:Uid="ScopeDialogAddFolder"
            AutomationProperties.AutomationId="ScopeDialogAddFolder"
            Click="AddFolder_Click" />

        <!--  入れ子の可視化(ADR-0025): 大きいフォルダに包含される選択を明示。  -->
        <TextBlock
            AutomationProperties.AutomationId="ScopeDialogCoverageNote"
            Foreground="{ThemeResource SystemFillColorCautionBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind VM.ScopeCoverageNote, Mode=OneWay}"
            TextWrapping="Wrap"
            Visibility="{x:Bind conv:UiConverters.VisibleIfNotEmpty(VM.ScopeCoverageNote), Mode=OneWay}" />

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!--  除外サブフォルダ(ADR-0025): root配下の特定フォルダを索引から外す。  -->
        <TextBlock x:Uid="ScopeDialogExcludesHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBlock
            x:Uid="ScopeDialogExcludesBody"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            TextWrapping="Wrap" />
        <ItemsControl AutomationProperties.AutomationId="ScopeDialogExcludes" ItemsSource="{x:Bind VM.ScopeExcludes, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid Margin="0,2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind}" />
                        <Button
                            Grid.Column="1"
                            Padding="8,4"
                            Click="RemoveExclude_Click"
                            Content="&#xE711;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="12"
                            Tag="{x:Bind}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button
            x:Uid="ScopeDialogAddExclude"
            AutomationProperties.AutomationId="ScopeDialogAddExclude"
            Click="AddExclude_Click" />

        <TextBlock
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Text="{x:Bind VM.DataLocationText, Mode=OneTime}"
            TextWrapping="Wrap"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsPortable)}" />
    </StackPanel>
</ContentDialog>
