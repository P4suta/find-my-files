<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="FindMyFiles.Views.ServiceManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:FindMyFiles.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="SvcDialog"
    AutomationProperties.AutomationId="ServiceManagerDialog"
    DefaultButton="Close"
    mc:Ignorable="d">

    <!--  fmf-engine のライフサイクル管理。各操作は Verb=runas の単発昇格
          (ServiceSetup.RunElevated)で、アプリ本体は非昇格のまま。状態行は
          読み取り専用 SCM クエリ(昇格不要)。  -->
    <StackPanel MinWidth="{StaticResource DialogMinWidth}" Spacing="{StaticResource SpacingLarge}">

        <!--  状態ヘッダー: アイコン(状態色)+ 状態テキスト + 進捗リング  -->
        <Grid ColumnSpacing="{StaticResource SpacingMedium}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--  状態色は ThemeResource を XAML で指定するため、3アイコンを出し分け。  -->
            <Grid Grid.Column="0" VerticalAlignment="Center">
                <FontIcon
                    FontSize="{StaticResource IconSizeMedium}"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Glyph="&#xE73E;"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsRunning), Mode=OneWay}" />
                <FontIcon
                    FontSize="{StaticResource IconSizeMedium}"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    Glyph="&#xE769;"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsStopped), Mode=OneWay}" />
                <FontIcon
                    FontSize="{StaticResource IconSizeMedium}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE946;"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsNotInstalled), Mode=OneWay}" />
            </Grid>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    AutomationProperties.AutomationId="SvcState"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind VM.StateText, Mode=OneWay}" />
                <TextBlock
                    x:Uid="SvcSubtitle"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
            <ProgressRing
                Grid.Column="2"
                Width="{StaticResource ProgressRingSizeMedium}"
                Height="{StaticResource ProgressRingSizeMedium}"
                VerticalAlignment="Center"
                IsActive="{x:Bind VM.Busy, Mode=OneWay}" />
        </Grid>

        <!--  稼働(登録済みのときのみ)  -->
        <StackPanel Spacing="{StaticResource CardSectionSpacing}" Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsInstalled), Mode=OneWay}">
            <TextBlock
                x:Uid="SvcGroupRunning"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                <Button
                    x:Uid="SvcStart"
                    AutomationProperties.AutomationId="SvcStart"
                    Click="Start_Click"
                    IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanStart), Mode=OneWay}" />
                <Button
                    x:Uid="SvcStop"
                    AutomationProperties.AutomationId="SvcStop"
                    Click="Stop_Click"
                    IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanStop), Mode=OneWay}" />
                <Button
                    x:Uid="SvcRestart"
                    AutomationProperties.AutomationId="SvcRestart"
                    Click="Restart_Click"
                    IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanRestart), Mode=OneWay}" />
            </StackPanel>
        </StackPanel>

        <!--  登録: 未登録ならアクセントの「登録して開始」、登録済みなら「登録し直す」  -->
        <StackPanel Spacing="{StaticResource CardSectionSpacing}" Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanRegister), Mode=OneWay}">
            <TextBlock
                x:Uid="SvcGroupRegister"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}" />
            <Button
                x:Uid="SvcRegister"
                AutomationProperties.AutomationId="SvcRegister"
                Click="Register_Click"
                IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}"
                Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsNotInstalled), Mode=OneWay}" />
            <Button
                x:Uid="SvcReregister"
                AutomationProperties.AutomationId="SvcReregister"
                Click="Register_Click"
                IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}"
                Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.IsInstalled), Mode=OneWay}" />
        </StackPanel>

        <!--  区切り線(削除ゾーンを明確に分離)  -->
        <Border
            Height="{StaticResource DividerHeight}"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
            Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanUninstall), Mode=OneWay}" />

        <!--  削除  -->
        <StackPanel Spacing="{StaticResource SpacingSmall}" Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.CanUninstall), Mode=OneWay}">
            <TextBlock
                x:Uid="SvcGroupDelete"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                <Button
                    x:Uid="SvcUninstall"
                    AutomationProperties.AutomationId="SvcUninstall"
                    Click="Uninstall_Click"
                    IsEnabled="{x:Bind VM.NotBusy, Mode=OneWay}" />
                <CheckBox
                    x:Uid="SvcPurgeData"
                    AutomationProperties.AutomationId="SvcPurgeData"
                    VerticalAlignment="Center"
                    IsChecked="{x:Bind VM.PurgeData, Mode=TwoWay}" />
            </StackPanel>
        </StackPanel>

        <!--  結果(色付き InfoBar)。登録/開始成功で空エンジンのときは再起動を促す。  -->
        <InfoBar
            AutomationProperties.AutomationId="SvcResult"
            IsClosable="False"
            IsOpen="{x:Bind VM.HasResult, Mode=OneWay}"
            Message="{x:Bind VM.ResultText, Mode=OneWay}"
            Severity="{x:Bind conv:UiConverters.ToInfoSeverity(VM.ResultSeverity), Mode=OneWay}">
            <InfoBar.ActionButton>
                <Button
                    x:Uid="SvcRestartApp"
                    AutomationProperties.AutomationId="SvcRestartApp"
                    Click="RestartApp_Click"
                    Visibility="{x:Bind conv:UiConverters.BoolToVis(VM.NeedsAppRestart), Mode=OneWay}" />
            </InfoBar.ActionButton>
        </InfoBar>
    </StackPanel>
</ContentDialog>
